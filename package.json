{
  "name": "discordbot",
  "version": "2.3.2",
  "description": "Colins little monster",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "lint": "eslint .",
    "start": "node index.js",
    "start:dev": "NODE_ENV=local node -r dotenv/config index.js dotenv_config_path=local.dev.env",
    "start:local": "NODE_ENV=local node index.js",
    "test": "jest test",
    "test:coverage": "jest test --coverage"
  },
  "author": "Colin",
  "license": "ISC",
  "dependencies": {
    "cron": "^3.1.7",
    "discord.js": "^14.15.2",
    "dotenv": "^16.6.1",
    "jimp": "^0.22.12",
    "request": "^2.88.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@types/jest": "^30.0.0",
    "eslint": "^9.6.0",
    "globals": "^15.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.2"
  },
  "jest": {
    "collectCoverageFrom": [
      "index.js",
      "commands/**/*.js",
      "!commands/**/*.test.js"
    ]
  }
}
